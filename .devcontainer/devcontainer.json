{
  "name": "Dev Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Toronto}"
    }
  },

  // NET_ADMIN and NET_RAW are required to run iptables inside the container
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--name=dev-sandbox-${localEnv:PROJECT_NAME}"
  ],

  // ${localWorkspaceFolder} resolves to the dev-sandbox directory on the host.
  // PROJECT_NAME and PROJECT_PATH are injected by open-devcontainer.ps1.
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    "source=${localEnv:PROJECT_PATH},target=/workspace/${localEnv:PROJECT_NAME},type=bind"
  ],

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/workspace/.claude",
    "UV_CACHE_DIR": "/workspace/.uv-data/cache"
  },

  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand",

  // Opens the multi-root workspace file after VS Code attaches to the container.
  // This pins the Explorer to exactly the folders for this session.
  "postAttachCommand": "code /workspace/workspace.code-workspace",
  
  "remoteUser": "dev"
}