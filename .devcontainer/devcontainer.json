{
  "name": "Dev Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Toronto}"
    }
  },

  // NET_ADMIN and NET_RAW are required to run iptables inside the container
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],

  // Option C: control dir with explicit project mounts
  // ${localWorkspaceFolder} resolves to /dev on the host
  // .devcontainer/ and .claude/ live under /dev; projects like hello-world are siblings of /dev
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    // Explicit project mounts
    "source=${localWorkspaceFolder}/../hello-world,target=/workspace/hello-world,type=bind"

  ],

  "containerEnv": {
    // Point Claude config at the bind-mounted host directory
    "CLAUDE_CONFIG_DIR": "/workspace/.claude",
    // Point uv config
    "UV_CACHE_DIR": "/workspace/.uv-data/cache"
  },

  // Run the firewall before VS Code opens -- waitFor ensures it is up first
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand",
  "remoteUser": "dev"
}